# Postgres connection string (Vercel Postgres, Neon, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host:5432/remoteote?sslmode=require"

# 32+ char random string for session cookie encryption
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# Cloudflare Turnstile keys (free at https://dash.cloudflare.com/?to=/:account/turnstile)
# Leave blank to use Cloudflare's "always-passes" public test keys (dev only).
# In real production, swap to keys from your Turnstile site to actually block bots.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
